{
  "name": "mmeditor",
  "version": "4.0.3",
  "description": "svg flow editor",
  "main": "./dist/MMEditor.js",
  "types": "./types/index.d.ts",
  "scripts": {
    "start": "webpack serve ",
    "build:demo": "webpack --mode production --config webpack.config.js",
    "build": "webpack --config webpack.config.build.js",
    "build:browser": "webpack --env browser=true --config webpack.config.build.js",
    "test:edge-label-rect": "node ./scripts/runEdgeLabelRectRefreshTest.js",
    "makeDts": "npx -p typescript tsc -p ./dts.json",
    "build:all": "npm run build && npm run makeDts && npm run build:browser && npm run build:demo",
    "lint": "npx tsc --noEmit",
    "test": "npm run build && npm run build:browser && npm run build:demo && npm run makeDts",
    "test:all": "npm run test && npm run test:edge-label-rect",
    "doc": "typedoc ",
    "watch": "webpack --watch --env browser=true --config webpack.config.build.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizy/mmeditor.git"
  },
  "keywords": [
    "mmeditor",
    "svg",
    "flow",
    "editor"
  ],
  "files": [
    "SKILL.md",
    "dist/MMEditor.js",
    "dist/MMEditor.browser.js",
    "types"
  ],
  "dependencies": {
    "canvg": "^4.0.0",
    "dagre": "^0.8.4",
    "gl-matrix": "^3.4.3",
    "url-loader": "^4.1.1",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@types/react": "^18.0.17",
    "antd": "^3.22.0",
    "babel-loader": "^8.0.2",
    "babel-plugin-import": "^1.12.0",
    "core-js": "^3.18.3",
    "css-loader": "^6.7.1",
    "fs-extra": "^10.1.0",
    "less": "^3.8.1",
    "less-loader": "^11.0.0",
    "react": "^16.0.0",
    "react-dom": "^16.0.0",
    "style-loader": "^3.3.1",
    "ts-loader": "^9.2.8",
    "tslib": "^2.3.1",
    "typedoc": "^0.23.8",
    "typescript": "^4.6.3",
    "webpack": "^5.71.0",
    "webpack-cli": "^4.9.2",
    "webpack-dev-server": "^4.7.4"
  },
  "author": "mizy",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mizy/mmeditor/issues"
  },
  "homepage": "https://github.com/mizy/mmeditor#readme"
}
